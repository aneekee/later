generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  password   String
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")

  chats                    Chat[]
  messageBurndownSnapshots MessageBurndownSnapshot[]

  @@map("users")
}

model Chat {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  createdAt DateTime @default(now()) @map("created_at")

  messages Message[]
  user     User      @relation(fields: [userId], references: [id])

  @@map("chats")
}

enum MessageType {
  TEXT

  @@map("message_type")
}

model Message {
  id        String      @id @default(uuid())
  type      MessageType @default(TEXT)
  chatId    String      @map("chat_id")
  createdAt DateTime    @default(now()) @map("created_at")

  chat              Chat               @relation(fields: [chatId], references: [id])
  textMessage       TextMessage?
  messageResolution MessageResolution?

  @@map("messages")
}

model TextMessage {
  id        String @id @default(uuid())
  messageId String @unique @map("message_id")
  content   String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("text_messages")
}

model MessageResolution {
  id        String   @id @default(uuid())
  messageId String   @unique @map("message_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_resolutions")
}

model MessageBurndownSnapshot {
  id            String   @id @default(uuid())
  day           DateTime @db.Date
  userId        String   @map("user_id")
  createdNotes  Int      @map("created_notes")
  resolvedNotes Int      @map("resolved_notes")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, day])
  @@map("message_burndown_snapshots")
}
